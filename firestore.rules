rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function hasExpenseAccess() {
      return request.auth != null
        && request.auth.token.expenseRole in ['superadmin', 'committee'];
    }

    function canManageExpenses() {
      return request.auth != null
        && request.auth.token.expenseRole == 'superadmin';
    }

    match /expenses/{expenseId} {
      allow read: if hasExpenseAccess();
      allow create, update, delete: if canManageExpenses();
    }

    match /app_settings/{docId} {
      allow read: if hasExpenseAccess();
      allow create, update, delete: if canManageExpenses();
    }
  }
}
