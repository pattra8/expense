rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function hasExpenseAccess() {
      return request.auth != null
        && request.auth.token.expenseRole in ['superadmin', 'committee'];
    }

    function canManageExpenses() {
      return request.auth != null
        && request.auth.token.expenseRole == 'superadmin';
    }

    match /expense-slips/{allPaths=**} {
      allow read: if hasExpenseAccess();
      allow write: if canManageExpenses();
    }
  }
}
